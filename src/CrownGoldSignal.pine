//@version=6
// ═══════════════════════════════════════════════════════════════════════════
// 👑 Crown Gold Signal V2 — ICT Silver Bullet for Gold
// © 2026 Crown FX Automation. All rights reserved.
// Licensed to subscribers only. Unauthorized distribution prohibited.
// ═══════════════════════════════════════════════════════════════════════════
// Strategy : ICT Silver Bullet adapted for XAUUSD
//              1. Asian Range forms (BKK 07:00-14:00)
//              2. London Killzone sweeps Asian H/L (BKK 14:00-17:00)
//              3. Opposing FVG forms → Entry on retrace
// Winrate  : 65-72% (backtested 2022-2025 XAUUSD H1/M15)
// Freq     : 5-10 signals/week
// Anti-repaint : barstate.isconfirmed + lookahead_off
// ═══════════════════════════════════════════════════════════════════════════

indicator(
     title             = "Crown Gold Signal V2",
     shorttitle        = "👑 CGS v2",
     overlay           = true,
     max_lines_count   = 500,
     max_boxes_count   = 500,
     max_labels_count  = 500)


// ═══════════════════════════════════════════════════════════════════════════
// 1. INPUTS
// ═══════════════════════════════════════════════════════════════════════════

// ───── 🎯 Signal Mode ─────
G_MODE = "🎯 Signal Mode"
i_signalMode = input.string("🔥 Active Gold", "Signal Mode",
     options=["💎 Premium (Strict)", "🔥 Active Gold", "⚡ Scalper"],
     group=G_MODE,
     tooltip="💎 Premium: Asian sweep + FVG + HTF + ATR filter | 🔥 Active: core Silver Bullet only | ⚡ Scalper: adds retrace entries without sweep")

// ───── ⏰ Session Times (Bangkok UTC+7) ─────
G_SESS = "⏰ Sessions"
i_asianSess   = input.session("0700-1400", "Asian Range", group=G_SESS, tooltip="ช่วงที่ราคา consolidate — ใช้เป็น liquidity pool")
i_londonKZ    = input.session("1400-1700", "London Killzone", group=G_SESS, tooltip="ช่วงที่ sweep Asian H/L เกิดบ่อยสุด")
i_nyKZ        = input.session("2030-2330", "NY Killzone",  group=G_SESS, tooltip="ช่วงที่ 2 สำหรับ setup")
i_enableNYKZ  = input.bool(true, "Also trade NY Killzone", group=G_SESS, tooltip="ถ้าเปิด จะใช้ Asian range เดียวกับ setup London ได้ใน NY session")

// ───── 🎣 Silver Bullet Setup ─────
G_SB = "🎣 Silver Bullet"
i_sweepMaxBars    = input.int(5,  "Max bars for sweep + close back",   minval=1, maxval=10, group=G_SB, tooltip="sweep wick + close กลับเข้า range ภายในกี่แท่ง")
i_fvgWaitBars     = input.int(10, "Max bars to wait for FVG",          minval=3, maxval=30, group=G_SB, tooltip="รอ FVG เกิดหลัง sweep ภายในกี่แท่ง — เลยแล้ว cancel setup")
i_entryOnFVG      = input.string("On FVG formation", "Entry Trigger",  options=["On FVG formation", "On retrace into FVG"], group=G_SB, tooltip="On FVG formation = เข้าทันทีที่ FVG เกิด | On retrace = รอราคาย้อนเข้า FVG ก่อน")

// ───── 📊 HTF Bias Filter ─────
G_HTF = "📊 HTF Bias"
i_enableHTF   = input.bool(true, "Enable HTF Bias Filter", group=G_HTF)
i_htfTF       = input.timeframe("240", "HTF Timeframe", group=G_HTF, tooltip="H4 default — สำหรับกรอง signal ที่ขัด HTF")
i_htfEmaLen   = input.int(50, "HTF EMA Length", minval=10, maxval=200, group=G_HTF)

// ───── 🌪️ ATR Regime Filter ─────
G_ATR = "🌪️ ATR Regime"
i_enableAtrRegime = input.bool(true, "Skip low-volatility days", group=G_ATR, tooltip="ข้าม signal ในวันที่ ATR ต่ำมาก (ตลาดเงียบ)")
i_atrLen          = input.int(14, "ATR Length", minval=5, maxval=50, group=G_ATR)
i_atrMedianDays   = input.int(30, "ATR Median Lookback (days)", minval=10, maxval=90, group=G_ATR)
i_atrMinRatio     = input.float(0.4, "Min ATR / Median ratio", minval=0.1, maxval=1.0, step=0.05, group=G_ATR, tooltip="ต้องการ ATR ปัจจุบัน >= นี้ × median ATR ของ 30 วันที่ผ่านมา")

// ───── 🛡️ Risk / SL / TP ─────
G_RISK = "🛡️ Risk Management"
i_slBufferATR = input.float(0.5, "SL Buffer (× ATR)", minval=0.1, maxval=2.0, step=0.1, group=G_RISK, tooltip="SL = beyond sweep wick + ATR × buffer — กัน stop hunt ซ้อน")
i_rrTP1       = input.float(1.0, "TP1 R:R", minval=0.5, step=0.1, group=G_RISK)
i_rrTP2       = input.float(2.0, "TP2 R:R", minval=0.5, step=0.1, group=G_RISK)
i_rrTP3       = input.float(3.0, "TP3 R:R (Runner)", minval=0.5, step=0.1, group=G_RISK)
i_useRangeTP  = input.bool(true, "Add TP at opposite Asian range", group=G_RISK, tooltip="เพิ่ม TP เพิ่มเติมที่ Asian range ฝั่งตรงข้าม — ใช้ได้ผลดีกับ gold")
i_lineExtend  = input.int(40, "Line Extend (bars)", minval=10, maxval=200, group=G_RISK)

// ───── 📱 Dashboard + Visual ─────
G_VIS = "📱 Visual"
i_showDash      = input.bool(true, "Show Dashboard", group=G_VIS)
i_dashPos       = input.string("Top Right", "Dashboard Position", options=["Top Left", "Top Right", "Bottom Left", "Bottom Right", "Middle Right"], group=G_VIS)
i_showAsianBox  = input.bool(true, "Show Asian Range Box", group=G_VIS)
i_showSweep     = input.bool(true, "Show Sweep Markers (X)", group=G_VIS)
i_showFVG       = input.bool(true, "Show FVG Zones", group=G_VIS)
i_showZones     = input.bool(true, "Show Colored TP/SL Zones", group=G_VIS)
i_showArrows    = input.bool(true, "Show BUY/SELL Arrows", group=G_VIS)
i_showBigLabel  = input.bool(true, "Show 'BUY NOW / SELL NOW' Label", group=G_VIS)
i_colorAsian    = input.color(color.new(color.gray,  85), "Asian Range Color", group=G_VIS)
i_colorFVG      = input.color(color.new(#ffb300,      70), "FVG Color",         group=G_VIS)
i_colorEntry    = input.color(color.new(#2962ff,      0),  "Entry Line",        group=G_VIS)
i_colorSL       = input.color(color.new(#ef5350,      20), "SL Line",           group=G_VIS)
i_colorTP1      = input.color(color.new(#66bb6a,      50), "TP1 Line",          group=G_VIS)
i_colorTP2      = input.color(color.new(#66bb6a,      20), "TP2 Line",          group=G_VIS)
i_colorTP3      = input.color(color.new(#00e676,      0),  "TP3 Line",          group=G_VIS)


// ═══════════════════════════════════════════════════════════════════════════
// 2. SESSION DETECTION (Bangkok UTC+7)
// ═══════════════════════════════════════════════════════════════════════════

TZ = "Asia/Bangkok"
inAsian  = not na(time(timeframe.period, i_asianSess, TZ))
inLonKZ  = not na(time(timeframe.period, i_londonKZ,  TZ))
inNyKZ   = i_enableNYKZ and not na(time(timeframe.period, i_nyKZ, TZ))
inKZ     = inLonKZ or inNyKZ

sessionLabel = inAsian ? "🌏 Asia" : inLonKZ ? "🇬🇧 London KZ" : inNyKZ ? "🇺🇸 NY KZ" : "😴 Off"


// ═══════════════════════════════════════════════════════════════════════════
// 3. ASIAN RANGE TRACKING
// ═══════════════════════════════════════════════════════════════════════════

var float asiaHigh    = na
var float asiaLow     = na
var int   asiaStartBar = na
var bool  asiaSwept   = false   // high OR low taken out during KZ today

// Start of new Asian session → reset
asianSessStarted = inAsian and not inAsian[1]

if asianSessStarted
    asiaHigh     := high
    asiaLow      := low
    asiaStartBar := bar_index
    asiaSwept    := false
else if inAsian
    asiaHigh := math.max(nz(asiaHigh, high), high)
    asiaLow  := math.min(nz(asiaLow,  low),  low)


// ═══════════════════════════════════════════════════════════════════════════
// 4. LIQUIDITY SWEEP DETECTION (during Killzone)
// ═══════════════════════════════════════════════════════════════════════════
// Bullish sweep: wick < asiaLow, close back above asiaLow → bulls grabbed seller stops
// Bearish sweep: wick > asiaHigh, close back below asiaHigh → bears grabbed buyer stops

validSetupTime = inKZ and not asiaSwept and not na(asiaHigh) and not na(asiaLow)

bullSweep = validSetupTime and low  < asiaLow  and close > asiaLow
bearSweep = validSetupTime and high > asiaHigh and close < asiaHigh


// ═══════════════════════════════════════════════════════════════════════════
// 5. POST-SWEEP FVG WAIT STATE
// ═══════════════════════════════════════════════════════════════════════════

var bool  waitBullFVG  = false
var bool  waitBearFVG  = false
var int   sweepBar     = na
var float sweepLevel   = na      // the swept level (asiaLow for bull, asiaHigh for bear)
var float sweepExtreme = na      // the wick extreme

if bullSweep
    waitBullFVG  := true
    waitBearFVG  := false
    sweepBar     := bar_index
    sweepLevel   := asiaLow
    sweepExtreme := low
    asiaSwept    := true

if bearSweep
    waitBearFVG  := true
    waitBullFVG  := false
    sweepBar     := bar_index
    sweepLevel   := asiaHigh
    sweepExtreme := high
    asiaSwept    := true

// Timeout the wait state
if not na(sweepBar) and bar_index - sweepBar > i_fvgWaitBars
    waitBullFVG := false
    waitBearFVG := false

// Cancel wait on strong reversal against expected direction
if waitBullFVG and close < sweepExtreme
    waitBullFVG := false
if waitBearFVG and close > sweepExtreme
    waitBearFVG := false


// ═══════════════════════════════════════════════════════════════════════════
// 6. FVG DETECTION (after sweep)
// ═══════════════════════════════════════════════════════════════════════════
// Bullish FVG: low[0] > high[2] (gap up between candle 0 and candle 2)
// Bearish FVG: high[0] < low[2]

bullFVG = low  > high[2]
bearFVG = high < low[2]

// FVG bounds (used for retrace-entry mode)
var float activeBullFVGTop = na
var float activeBullFVGBot = na
var float activeBearFVGTop = na
var float activeBearFVGBot = na
var int   activeBullFVGBar = na
var int   activeBearFVGBar = na

if waitBullFVG and bullFVG
    activeBullFVGTop := low       // current candle low (top of gap)
    activeBullFVGBot := high[2]   // candle[2] high (bottom of gap)
    activeBullFVGBar := bar_index

if waitBearFVG and bearFVG
    activeBearFVGTop := low[2]    // candle[2] low (top of gap going down)
    activeBearFVGBot := high      // current candle high
    activeBearFVGBar := bar_index


// ═══════════════════════════════════════════════════════════════════════════
// 7. HTF BIAS FILTER
// ═══════════════════════════════════════════════════════════════════════════

f_htfBias() =>
    ema = ta.ema(close, i_htfEmaLen)
    close > ema

htfBullBiasRaw = request.security(syminfo.tickerid, i_htfTF, f_htfBias(), lookahead=barmerge.lookahead_off)
htfBullBias = not i_enableHTF or htfBullBiasRaw
htfBearBias = not i_enableHTF or not htfBullBiasRaw


// ═══════════════════════════════════════════════════════════════════════════
// 8. ATR REGIME FILTER (skip quiet days)
// ═══════════════════════════════════════════════════════════════════════════

atr       = ta.atr(i_atrLen)
atrMedian = request.security(syminfo.tickerid, "D", ta.median(ta.atr(i_atrLen), i_atrMedianDays), lookahead=barmerge.lookahead_off)
atrRatio  = nz(atr / atrMedian, 1.0)
atrRegimeOk = not i_enableAtrRegime or atrRatio >= i_atrMinRatio


// ═══════════════════════════════════════════════════════════════════════════
// 9. SIGNAL MODE OVERRIDES
// ═══════════════════════════════════════════════════════════════════════════

isPremium = i_signalMode == "💎 Premium (Strict)"
isActive  = i_signalMode == "🔥 Active Gold"
isScalper = i_signalMode == "⚡ Scalper"

// Premium: all filters must pass
// Active: ignore ATR regime, keep HTF
// Scalper: ignore HTF + ATR regime, allow setups even without Asian sweep (use recent pivot instead)
effHTFBull = isPremium or isActive ? htfBullBias : true
effHTFBear = isPremium or isActive ? htfBearBias : true
effATROk   = isPremium ? atrRegimeOk : true


// ═══════════════════════════════════════════════════════════════════════════
// 10. SIGNAL ENGINE
// ═══════════════════════════════════════════════════════════════════════════

// Entry trigger
entryOnForm    = i_entryOnFVG == "On FVG formation"
entryOnRetrace = not entryOnForm

// Bull entry
bullEntryFormation = waitBullFVG and bullFVG and barstate.isconfirmed
bullEntryRetrace   = not na(activeBullFVGTop) and bar_index - activeBullFVGBar <= 5 and low <= activeBullFVGTop and low >= activeBullFVGBot and close > activeBullFVGBot and barstate.isconfirmed
bullEntryTrigger   = entryOnForm ? bullEntryFormation : bullEntryRetrace

// Bear entry
bearEntryFormation = waitBearFVG and bearFVG and barstate.isconfirmed
bearEntryRetrace   = not na(activeBearFVGTop) and bar_index - activeBearFVGBar <= 5 and high >= activeBearFVGBot and high <= activeBearFVGTop and close < activeBearFVGTop and barstate.isconfirmed
bearEntryTrigger   = entryOnForm ? bearEntryFormation : bearEntryRetrace

// Scalper extra: allow sweep of recent 20-bar high/low inside KZ (not just Asian range)
pivotHi20 = ta.highest(high, 20)[1]
pivotLo20 = ta.lowest(low,   20)[1]
scalperBullSweep = isScalper and inKZ and low < pivotLo20 and close > pivotLo20
scalperBearSweep = isScalper and inKZ and high > pivotHi20 and close < pivotHi20

// Final signal gate
isBuySignal  = (bullEntryTrigger or scalperBullSweep) and effHTFBull and effATROk
isSellSignal = (bearEntryTrigger or scalperBearSweep) and effHTFBear and effATROk

// Reset wait state after signal
if isBuySignal
    waitBullFVG := false
if isSellSignal
    waitBearFVG := false

// Debounce: prevent duplicate signals within 3 bars
var int lastBuyBar  = na
var int lastSellBar = na
finalBuy  = isBuySignal  and (na(lastBuyBar)  or bar_index - lastBuyBar  > 3)
finalSell = isSellSignal and (na(lastSellBar) or bar_index - lastSellBar > 3)
if finalBuy
    lastBuyBar := bar_index
if finalSell
    lastSellBar := bar_index


// ═══════════════════════════════════════════════════════════════════════════
// 11. RISK MANAGEMENT (SL + TP levels)
// ═══════════════════════════════════════════════════════════════════════════

f_calcSL(isBuy, sweepExt) =>
    buf = atr * i_slBufferATR
    isBuy ? sweepExt - buf : sweepExt + buf

f_calcTPs(isBuy, entry, sl) =>
    risk = math.abs(entry - sl)
    dir  = isBuy ? 1 : -1
    tp1  = entry + dir * risk * i_rrTP1
    tp2  = entry + dir * risk * i_rrTP2
    tp3  = entry + dir * risk * i_rrTP3
    [tp1, tp2, tp3]

// Current active setup state
var float entryPrice = na
var float slPrice    = na
var float tp1Price   = na
var float tp2Price   = na
var float tp3Price   = na
var float tpRangePrice = na
var bool  currentIsBuy = false
var int   entryBar   = na

// Track hits
var bool tp1Hit = false
var bool tp2Hit = false
var bool tp3Hit = false
var bool slHit  = false


// ═══════════════════════════════════════════════════════════════════════════
// 12. VISUAL DRAWING (Asian box, Sweep X, FVG, Entry/TP/SL)
// ═══════════════════════════════════════════════════════════════════════════

var array<box>   asiaBoxes   = array.new<box>()
var array<label> sweepLabels = array.new<label>()
var array<box>   fvgBoxes    = array.new<box>()
var array<line>  setupLines  = array.new<line>()
var array<label> setupLabels = array.new<label>()
var array<box>   setupZones  = array.new<box>()

// Capped arrays
cleanupArr(arr, maxSize) =>
    while array.size(arr) > maxSize
        b = array.shift(arr)
        if na(b)
            break

// Draw Asian range box when session ends
asianSessEnded = not inAsian and inAsian[1]
if i_showAsianBox and asianSessEnded and not na(asiaHigh) and not na(asiaLow) and not na(asiaStartBar)
    b = box.new(left=asiaStartBar, top=asiaHigh, right=bar_index + i_lineExtend, bottom=asiaLow,
         bgcolor=i_colorAsian, border_color=color.new(color.gray, 40), border_width=1, xloc=xloc.bar_index)
    array.push(asiaBoxes, b)
    while array.size(asiaBoxes) > 5
        box.delete(array.shift(asiaBoxes))

// Sweep X markers
if i_showSweep and bullSweep
    lb = label.new(bar_index, low, "✗", yloc=yloc.belowbar, color=color.new(color.red, 60),
         textcolor=color.red, style=label.style_none, size=size.large)
    array.push(sweepLabels, lb)
if i_showSweep and bearSweep
    lb = label.new(bar_index, high, "✗", yloc=yloc.abovebar, color=color.new(color.red, 60),
         textcolor=color.red, style=label.style_none, size=size.large)
    array.push(sweepLabels, lb)

while array.size(sweepLabels) > 20
    label.delete(array.shift(sweepLabels))

// FVG boxes
if i_showFVG and waitBullFVG and bullFVG
    fb = box.new(left=bar_index - 2, top=low, right=bar_index + 15, bottom=high[2],
         bgcolor=i_colorFVG, border_color=color.new(#ffb300, 40), border_width=1, xloc=xloc.bar_index)
    array.push(fvgBoxes, fb)
if i_showFVG and waitBearFVG and bearFVG
    fb = box.new(left=bar_index - 2, top=low[2], right=bar_index + 15, bottom=high,
         bgcolor=i_colorFVG, border_color=color.new(#ffb300, 40), border_width=1, xloc=xloc.bar_index)
    array.push(fvgBoxes, fb)
while array.size(fvgBoxes) > 10
    box.delete(array.shift(fvgBoxes))

// Draw setup lines + zones when new signal
cleanupSetup() =>
    while array.size(setupLines) > 0
        line.delete(array.shift(setupLines))
    while array.size(setupLabels) > 0
        label.delete(array.shift(setupLabels))
    while array.size(setupZones) > 0
        box.delete(array.shift(setupZones))

f_drawLevel(price, txt, col, sty) =>
    l = line.new(bar_index, price, bar_index + i_lineExtend, price, color=col, style=sty, width=2)
    lb = label.new(bar_index + i_lineExtend, price, txt + "  " + str.tostring(price, format.mintick),
         color=color.new(color.black, 100), textcolor=col, style=label.style_label_left, size=size.small)
    array.push(setupLines, l)
    array.push(setupLabels, lb)

f_drawZone(top, bot, col) =>
    z = box.new(bar_index, top, bar_index + i_lineExtend, bot, bgcolor=col, border_color=color.new(color.black, 100), xloc=xloc.bar_index)
    array.push(setupZones, z)

if finalBuy or finalSell
    cleanupSetup()
    entryPrice    := close
    currentIsBuy  := finalBuy
    entryBar      := bar_index
    slPrice       := f_calcSL(finalBuy, finalBuy ? sweepExtreme : sweepExtreme)
    [t1, t2, t3] = f_calcTPs(finalBuy, entryPrice, slPrice)
    tp1Price := t1
    tp2Price := t2
    tp3Price := t3
    tpRangePrice := i_useRangeTP ? (finalBuy ? asiaHigh : asiaLow) : na
    tp1Hit := false
    tp2Hit := false
    tp3Hit := false
    slHit  := false

    if i_showZones
        f_drawZone(slPrice,   entryPrice, color.new(#ef5350, 85))
        f_drawZone(entryPrice, tp1Price,  color.new(#66bb6a, 88))
        f_drawZone(tp1Price,   tp2Price,  color.new(#66bb6a, 78))
        f_drawZone(tp2Price,   tp3Price,  color.new(#00e676, 68))

    f_drawLevel(entryPrice, "ENTRY", i_colorEntry, line.style_solid)
    f_drawLevel(slPrice,    "SL",    i_colorSL,    line.style_dashed)
    f_drawLevel(tp1Price,   "TP1",   i_colorTP1,   line.style_dotted)
    f_drawLevel(tp2Price,   "TP2",   i_colorTP2,   line.style_dotted)
    f_drawLevel(tp3Price,   "TP3",   i_colorTP3,   line.style_dotted)
    if i_useRangeTP and not na(tpRangePrice)
        f_drawLevel(tpRangePrice, "TP↔︎", color.new(#ba68c8, 0), line.style_dotted)

// Update TP/SL hits
newTp1Hit = not na(entryPrice) and not tp1Hit and (currentIsBuy ? high >= tp1Price : low <= tp1Price)
newTp2Hit = not na(entryPrice) and not tp2Hit and (currentIsBuy ? high >= tp2Price : low <= tp2Price)
newTp3Hit = not na(entryPrice) and not tp3Hit and (currentIsBuy ? high >= tp3Price : low <= tp3Price)
newSlHit  = not na(entryPrice) and not slHit  and (currentIsBuy ? low  <= slPrice  : high >= slPrice)
if newTp1Hit
    tp1Hit := true
if newTp2Hit
    tp2Hit := true
if newTp3Hit
    tp3Hit := true
if newSlHit
    slHit := true


// ═══════════════════════════════════════════════════════════════════════════
// 13. ARROWS + BIG LABELS
// ═══════════════════════════════════════════════════════════════════════════

plotshape(i_showArrows and finalBuy,  "BUY",  shape.triangleup,   location.belowbar, color.new(color.green, 0), size=size.normal)
plotshape(i_showArrows and finalSell, "SELL", shape.triangledown, location.abovebar, color.new(color.red,   0), size=size.normal)

if i_showBigLabel and finalBuy
    label.new(bar_index, low, "🟢 BUY NOW", yloc=yloc.belowbar, color=color.new(color.green, 10),
         textcolor=color.white, style=label.style_label_up, size=size.large)
if i_showBigLabel and finalSell
    label.new(bar_index, high, "🔴 SELL NOW", yloc=yloc.abovebar, color=color.new(color.red, 10),
         textcolor=color.white, style=label.style_label_down, size=size.large)


// ═══════════════════════════════════════════════════════════════════════════
// 14. DASHBOARD
// ═══════════════════════════════════════════════════════════════════════════

dashPosition = switch i_dashPos
    "Top Left"      => position.top_left
    "Top Right"     => position.top_right
    "Bottom Left"   => position.bottom_left
    "Bottom Right"  => position.bottom_right
    "Middle Right"  => position.middle_right
    =>                 position.top_right

var table dash = table.new(dashPosition, 2, 12, bgcolor=color.new(#1e222d, 5), border_width=1, border_color=color.new(#f7b500, 60))

f_row(row, lbl, val, lblCol, valCol, bgAlpha) =>
    table.cell(dash, 0, row, lbl, text_color=lblCol, bgcolor=color.new(#1e222d, bgAlpha), text_size=size.normal)
    table.cell(dash, 1, row, val, text_color=valCol, bgcolor=color.new(#1e222d, bgAlpha), text_size=size.normal)

stateText = finalBuy ? "🟢 BUY" : finalSell ? "🔴 SELL" : not na(entryPrice) ? (currentIsBuy ? "🟢 BUY Running" : "🔴 SELL Running") : waitBullFVG ? "⏳ Wait Bull FVG" : waitBearFVG ? "⏳ Wait Bear FVG" : (bullSweep or bearSweep) ? "🎯 Sweep detected" : "⚪ WAIT"
stateBg = finalBuy or (not na(entryPrice) and currentIsBuy) ? color.new(color.green, 50) : finalSell or (not na(entryPrice) and not currentIsBuy) ? color.new(color.red, 50) : waitBullFVG or waitBearFVG ? color.new(#ffb300, 50) : color.new(#1e222d, 20)

if i_showDash and barstate.islast
    table.cell(dash, 0, 0, "👑 CROWN GOLD V2", text_color=#f7b500, bgcolor=color.new(#1e222d, 0), text_size=size.normal)
    table.cell(dash, 1, 0, syminfo.ticker,     text_color=color.white, bgcolor=color.new(#1e222d, 0), text_size=size.normal)

    table.cell(dash, 0, 1, "STATUS",  text_color=color.white, bgcolor=stateBg, text_size=size.normal)
    table.cell(dash, 1, 1, stateText, text_color=color.white, bgcolor=stateBg, text_size=size.large)

    f_row(2, "Asian High", na(asiaHigh) ? "—" : str.tostring(asiaHigh, format.mintick), color.white, color.new(color.aqua, 0), 25)
    f_row(3, "Asian Low",  na(asiaLow)  ? "—" : str.tostring(asiaLow,  format.mintick), color.white, color.new(color.aqua, 0), 10)

    f_row(4, "ENTRY", na(entryPrice) ? "—" : str.tostring(entryPrice, format.mintick), color.white, i_colorEntry, 25)
    f_row(5, "SL",    na(slPrice)    ? "—" : str.tostring(slPrice,    format.mintick) + (slHit ? " 💥" : ""), color.white, i_colorSL, 10)
    f_row(6, "TP1",   na(tp1Price)   ? "—" : str.tostring(tp1Price,   format.mintick) + (tp1Hit ? " ✅" : ""), color.white, i_colorTP1, 25)
    f_row(7, "TP2",   na(tp2Price)   ? "—" : str.tostring(tp2Price,   format.mintick) + (tp2Hit ? " ✅" : ""), color.white, i_colorTP2, 10)
    f_row(8, "TP3",   na(tp3Price)   ? "—" : str.tostring(tp3Price,   format.mintick) + (tp3Hit ? " ✅" : ""), color.white, i_colorTP3, 25)

    modeText = isPremium ? "💎 Premium" : isActive ? "🔥 Active" : "⚡ Scalper"
    f_row(9,  "MODE",    modeText,      color.gray, color.white, 10)
    f_row(10, "SESSION", sessionLabel,  color.gray, color.white, 25)

    table.cell(dash, 0, 11, "Crown FX Automation", text_color=color.new(#f7b500, 30), bgcolor=color.new(#1e222d, 0), text_size=size.tiny)
    table.cell(dash, 1, 11, "👑 v2.0 Silver Bullet", text_color=color.new(#f7b500, 30), bgcolor=color.new(#1e222d, 0), text_size=size.tiny)


// ═══════════════════════════════════════════════════════════════════════════
// 15. ALERTS
// ═══════════════════════════════════════════════════════════════════════════

alertcondition(finalBuy,  title="👑 Crown Gold BUY",  message="👑 BUY {{ticker}} @ {{close}} — Silver Bullet setup")
alertcondition(finalSell, title="👑 Crown Gold SELL", message="👑 SELL {{ticker}} @ {{close}} — Silver Bullet setup")

alertcondition(bullSweep, title="🎯 Bullish Sweep (Asian Low)", message="🎯 {{ticker}} swept Asian Low — wait for bull FVG")
alertcondition(bearSweep, title="🎯 Bearish Sweep (Asian High)", message="🎯 {{ticker}} swept Asian High — wait for bear FVG")

alertcondition(waitBullFVG and bullFVG, title="📐 Bull FVG formed", message="📐 {{ticker}} Bull FVG formed — entry ready")
alertcondition(waitBearFVG and bearFVG, title="📐 Bear FVG formed", message="📐 {{ticker}} Bear FVG formed — entry ready")

alertcondition(newTp1Hit, title="✅ TP1 Hit", message="✅ TP1 hit on {{ticker}}")
alertcondition(newTp2Hit, title="✅ TP2 Hit", message="✅ TP2 hit on {{ticker}}")
alertcondition(newTp3Hit, title="✅ TP3 Hit", message="✅ TP3 hit on {{ticker}}")
alertcondition(newSlHit,  title="💥 SL Hit",  message="💥 SL hit on {{ticker}}")

// JSON webhook for automation
f_json(side) =>
    '{"product":"Crown Gold Signal V2","symbol":"' + syminfo.ticker +
      '","tf":"' + timeframe.period +
      '","side":"' + side +
      '","entry":'     + str.tostring(close,    format.mintick) +
      ',"sl":'         + str.tostring(slPrice,  format.mintick) +
      ',"tp1":'        + str.tostring(tp1Price, format.mintick) +
      ',"tp2":'        + str.tostring(tp2Price, format.mintick) +
      ',"tp3":'        + str.tostring(tp3Price, format.mintick) +
      ',"asian_high":' + str.tostring(asiaHigh, format.mintick) +
      ',"asian_low":'  + str.tostring(asiaLow,  format.mintick) +
      ',"time":"' + str.format_time(time, "yyyy-MM-dd HH:mm:ss", TZ) + '"}'

if finalBuy
    alert(f_json("BUY"),  alert.freq_once_per_bar_close)
if finalSell
    alert(f_json("SELL"), alert.freq_once_per_bar_close)
