//@version=6
// ═══════════════════════════════════════════════════════════════════════════
// 👑 Crown Gold Signal — Strategy Version (for Backtest)
// © 2026 Crown FX Automation. All rights reserved.
// ═══════════════════════════════════════════════════════════════════════════
// Backtest-ready version of Crown Gold Signal indicator.
// Same 3-condition signal logic, with strategy.entry/exit for TradingView
// Strategy Tester. Use this to validate winrate / PF / max DD before publish.
// ═══════════════════════════════════════════════════════════════════════════

strategy(
     title                  = "Crown Gold Signal — Strategy",
     shorttitle             = "👑 CGS Strategy",
     overlay                = true,
     initial_capital        = 10000,
     default_qty_type       = strategy.percent_of_equity,
     default_qty_value      = 100,
     commission_type        = strategy.commission.percent,
     commission_value       = 0.02,
     slippage               = 2,
     pyramiding             = 0,
     calc_on_every_tick     = false,
     process_orders_on_close= true,
     max_lines_count        = 500,
     max_boxes_count        = 500,
     max_labels_count       = 500)


// ═══════════════════════════════════════════════════════════════════════════
// 1. INPUTS (mirrors indicator — plus backtest controls)
// ═══════════════════════════════════════════════════════════════════════════

G_SIGNAL = "🎯 Signal Settings"
i_signalMode = input.string("🔥 Active Gold", "Signal Mode", options=["💎 Premium OTE", "🔥 Active Gold", "⚡ Scalper"], group=G_SIGNAL, tooltip="💎 Premium OTE: ~1 signal/เดือน, Winrate 90%+  |  🔥 Active Gold: ~5-10/สัปดาห์, WR 55-65%  |  ⚡ Scalper: ~10-20/สัปดาห์, WR 50-55%")
i_emaFast    = input.int(50,  "EMA Fast",   minval=2,  maxval=500, group=G_SIGNAL)
i_emaSlow    = input.int(200, "EMA Slow",   minval=10, maxval=500, group=G_SIGNAL)
i_rsiLen     = input.int(14,  "RSI Length", group=G_SIGNAL)
i_rsiBuyMin  = input.int(50,  "RSI Buy Min",  group=G_SIGNAL)
i_rsiBuyMax  = input.int(70,  "RSI Buy Max",  group=G_SIGNAL)
i_rsiSellMin = input.int(30,  "RSI Sell Min", group=G_SIGNAL)
i_rsiSellMax = input.int(50,  "RSI Sell Max", group=G_SIGNAL)
i_macdFast   = input.int(12, "MACD Fast",   group=G_SIGNAL)
i_macdSlow   = input.int(26, "MACD Slow",   group=G_SIGNAL)
i_macdSignal = input.int(9,  "MACD Signal", group=G_SIGNAL)

G_MTF = "📊 Multi-Timeframe"
i_enableMTF = input.bool(true, "Enable HTF Filter", group=G_MTF)
i_htf1      = input.timeframe("60",  "HTF 1", group=G_MTF)
i_htf2      = input.timeframe("240", "HTF 2", group=G_MTF)

G_RISK = "🛡️ Risk Management"
i_atrLen        = input.int(14, "ATR Length", group=G_RISK)
i_atrMult       = input.float(1.5, "ATR Multiplier (SL)", step=0.1, group=G_RISK)
i_useSwingSL    = input.bool(true, "Use Swing H/L for SL (if farther)", group=G_RISK)
i_swingLookback = input.int(10, "Swing Lookback", group=G_RISK)
i_rrTP1         = input.float(1.0, "TP1 R:R", step=0.1, group=G_RISK)
i_rrTP2         = input.float(2.0, "TP2 R:R", step=0.1, group=G_RISK)
i_rrTP3         = input.float(3.0, "TP3 R:R", step=0.1, group=G_RISK)
i_rrTP4         = input.float(5.0, "TP4 R:R", step=0.1, group=G_RISK)

G_SMC = "🧠 SMC Settings"
i_enableOB  = input.bool(true, "Use Order Block Structure", group=G_SMC)
i_enableFVG = input.bool(true, "Use FVG Structure", group=G_SMC)
i_pivotLen  = input.int(5, "Pivot Lookback", group=G_SMC)
i_maxZones  = input.int(5, "Max SMC Zones", group=G_SMC)

G_SESSION = "⏰ Session / Kill Zone"
i_enableSession = input.bool(true,  "Enable Session Filter", group=G_SESSION)
i_useKZ         = input.bool(false, "Use narrow Kill Zone times ⭐", group=G_SESSION, tooltip="⭐ London 14-17 + NY 19:30-23 (gold spike peak)")
i_sessionLondon = input.bool(true, "Include London", group=G_SESSION)
i_sessionNY     = input.bool(true, "Include New York", group=G_SESSION)

G_FIB = "📐 Fibonacci OTE"
i_fibLookback = input.int(50, "Fib Swing Lookback", minval=10, maxval=500, group=G_FIB)
i_requireOTE  = input.bool(false, "Require Price in OTE Zone (78.6-88.6) ⭐", group=G_FIB, tooltip="⭐ Gold Deep Retracement — entry เฉพาะเมื่อราคาอยู่ในโซน OTE")

G_ADV = "🎯 Advanced Signals"
i_enableLiqSweep  = input.bool(true, "Enable Liquidity Sweep ⭐", group=G_ADV)
i_enableHiddenDiv = input.bool(true, "Enable Hidden Divergence ⭐", group=G_ADV)
i_htfMinScore     = input.int(2, "HTF Min Score (−4 to +4)", minval=-4, maxval=4, group=G_ADV)

G_POS = "📐 Position Management"
i_tp1Pct = input.float(30, "TP1 Close %", minval=0, maxval=100, group=G_POS, tooltip="ปิดกี่ % ของ position ที่ TP1")
i_tp2Pct = input.float(30, "TP2 Close %", minval=0, maxval=100, group=G_POS)
i_tp3Pct = input.float(25, "TP3 Close %", minval=0, maxval=100, group=G_POS)
// Remaining (~15%) runs to TP4

G_BT = "📅 Backtest Window"
i_useDateFilter = input.bool(true, "Use Date Range Filter", group=G_BT)
i_startDate     = input.time(timestamp("2024-01-01 00:00"), "Start Date", group=G_BT)
i_endDate       = input.time(timestamp("2026-12-31 23:59"), "End Date",   group=G_BT)

inDateWindow = not i_useDateFilter or (time >= i_startDate and time <= i_endDate)


// ═══════════════════════════════════════════════════════════════════════════
// 2. INDICATORS + MULTI-TF (same as indicator)
// ═══════════════════════════════════════════════════════════════════════════

emaFast = ta.ema(close, i_emaFast)
emaSlow = ta.ema(close, i_emaSlow)
rsi     = ta.rsi(close, i_rsiLen)
[macdLine, macdSig, _mh] = ta.macd(close, i_macdFast, i_macdSlow, i_macdSignal)
atr     = ta.atr(i_atrLen)

f_htfBias() =>
    ef = ta.ema(close, i_emaFast)
    es = ta.ema(close, i_emaSlow)
    [ef > es and close > es, ef < es and close < es]

[htf1BullRaw, htf1BearRaw] = request.security(syminfo.tickerid, i_htf1, f_htfBias(), lookahead=barmerge.lookahead_off)
[htf2BullRaw, htf2BearRaw] = request.security(syminfo.tickerid, i_htf2, f_htfBias(), lookahead=barmerge.lookahead_off)

htf1Bull = i_enableMTF ? htf1BullRaw : true
htf1Bear = i_enableMTF ? htf1BearRaw : true
htf2Bull = i_enableMTF ? htf2BullRaw : true
htf2Bear = i_enableMTF ? htf2BearRaw : true

htfBullBias = not i_enableMTF or (htf1Bull and htf2Bull)
htfBearBias = not i_enableMTF or (htf1Bear and htf2Bear)


// ═══════════════════════════════════════════════════════════════════════════
// 3. SMC (same logic as indicator — structure booleans only, no visual boxes)
// ═══════════════════════════════════════════════════════════════════════════

pivotHigh = ta.pivothigh(high, i_pivotLen, i_pivotLen)
pivotLow  = ta.pivotlow (low,  i_pivotLen, i_pivotLen)

var float lastSwingHigh = na
var float lastSwingLow  = na
if not na(pivotHigh)
    lastSwingHigh := pivotHigh
if not na(pivotLow)
    lastSwingLow := pivotLow

bosBull = not na(lastSwingHigh) and close > lastSwingHigh and close[1] <= lastSwingHigh
bosBear = not na(lastSwingLow)  and close < lastSwingLow  and close[1] >= lastSwingLow

var array<float> bullOBTops = array.new<float>()
var array<float> bullOBBots = array.new<float>()
var array<float> bearOBTops = array.new<float>()
var array<float> bearOBBots = array.new<float>()

if i_enableOB and bosBull
    for i = 1 to 10
        if close[i] < open[i]
            array.push(bullOBTops, math.max(open[i], close[i]))
            array.push(bullOBBots, math.min(low[i],  close[i]))
            if array.size(bullOBTops) > i_maxZones
                array.shift(bullOBTops)
                array.shift(bullOBBots)
            break
if i_enableOB and bosBear
    for i = 1 to 10
        if close[i] > open[i]
            array.push(bearOBTops, math.max(high[i], close[i]))
            array.push(bearOBBots, math.min(open[i], close[i]))
            if array.size(bearOBTops) > i_maxZones
                array.shift(bearOBTops)
                array.shift(bearOBBots)
            break

var array<float> bullFVGTops = array.new<float>()
var array<float> bullFVGBots = array.new<float>()
var array<float> bearFVGTops = array.new<float>()
var array<float> bearFVGBots = array.new<float>()

if i_enableFVG and low > high[2]
    array.push(bullFVGTops, low)
    array.push(bullFVGBots, high[2])
    if array.size(bullFVGTops) > i_maxZones
        array.shift(bullFVGTops)
        array.shift(bullFVGBots)
if i_enableFVG and high < low[2]
    array.push(bearFVGTops, low[2])
    array.push(bearFVGBots, high)
    if array.size(bearFVGTops) > i_maxZones
        array.shift(bearFVGTops)
        array.shift(bearFVGBots)

isTouchingZone(tops, bots) =>
    touched = false
    n = array.size(tops)
    if n > 0
        for i = 0 to n - 1
            t = array.get(tops, i)
            b = array.get(bots, i)
            if low <= t and high >= b
                touched := true
                break
    touched

smcBullStructure = isTouchingZone(bullOBTops, bullOBBots) or isTouchingZone(bullFVGTops, bullFVGBots) or bosBull
smcBearStructure = isTouchingZone(bearOBTops, bearOBBots) or isTouchingZone(bearFVGTops, bearFVGBots) or bosBear


// ═══════════════════════════════════════════════════════════════════════════
// 4. SESSION FILTER
// ═══════════════════════════════════════════════════════════════════════════

londonSess = i_useKZ ? "1400-1700" : "1500-0000"
nySess     = i_useKZ ? "1930-2300" : "2000-0500"
inLondon   = not na(time(timeframe.period, londonSess, "Asia/Bangkok"))
inNY       = not na(time(timeframe.period, nySess,     "Asia/Bangkok"))
activeSession = not i_enableSession or ((i_sessionLondon and inLondon) or (i_sessionNY and inNY))

// OTE Zone (Deep Retracement 78.6-88.6)
oteHi      = ta.highest(high, i_fibLookback)
oteLo      = ta.lowest (low,  i_fibLookback)
oteRng     = oteHi - oteLo
oteZoneTop = oteHi - oteRng * 0.786
oteZoneBot = oteHi - oteRng * 0.886
inOTEZone  = not na(oteZoneTop) and not na(oteZoneBot) and low <= oteZoneTop and high >= oteZoneBot
oteFilter  = not i_requireOTE or inOTEZone

// Liquidity Sweep (stop hunt)
bullSweep = i_enableLiqSweep and not na(lastSwingLow)  and low  < lastSwingLow  and close > lastSwingLow
bearSweep = i_enableLiqSweep and not na(lastSwingHigh) and high > lastSwingHigh and close < lastSwingHigh

// Hidden Divergence — pivot-based (no repaint)
var float prevPivotLow_s     = na
var float lastPivotLow_s     = na
var float prevPivotLowRsi_s  = na
var float lastPivotLowRsi_s  = na
var float prevPivotHigh_s    = na
var float lastPivotHigh_s    = na
var float prevPivotHighRsi_s = na
var float lastPivotHighRsi_s = na
if not na(pivotLow)
    prevPivotLow_s    := lastPivotLow_s
    prevPivotLowRsi_s := lastPivotLowRsi_s
    lastPivotLow_s    := pivotLow
    lastPivotLowRsi_s := rsi[i_pivotLen]
if not na(pivotHigh)
    prevPivotHigh_s    := lastPivotHigh_s
    prevPivotHighRsi_s := lastPivotHighRsi_s
    lastPivotHigh_s    := pivotHigh
    lastPivotHighRsi_s := rsi[i_pivotLen]
hiddenDivBull = i_enableHiddenDiv and not na(pivotLow)  and not na(prevPivotLow_s)  and not na(prevPivotLowRsi_s)  and lastPivotLow_s  > prevPivotLow_s  and lastPivotLowRsi_s  < prevPivotLowRsi_s
hiddenDivBear = i_enableHiddenDiv and not na(pivotHigh) and not na(prevPivotHigh_s) and not na(prevPivotHighRsi_s) and lastPivotHigh_s < prevPivotHigh_s and lastPivotHighRsi_s > prevPivotHighRsi_s

// HTF scoring
htf1Score = htf1BullRaw ? 2 : htf1BearRaw ? -2 : 1
htf2Score = htf2BullRaw ? 2 : htf2BearRaw ? -2 : 1
htfTotalScore = htf1Score + htf2Score
htfScorePassBull = not i_enableMTF or htfTotalScore >=  i_htfMinScore
htfScorePassBear = not i_enableMTF or htfTotalScore <= -i_htfMinScore


// ═══════════════════════════════════════════════════════════════════════════
// 5. SIGNAL ENGINE (3-condition, same as indicator)
// ═══════════════════════════════════════════════════════════════════════════

// ───── Signal Mode Overrides (same logic as indicator) ─────
isPremium = i_signalMode == "💎 Premium OTE"
isActive  = i_signalMode == "🔥 Active Gold"
isScalper = i_signalMode == "⚡ Scalper"

effRequireSMC = isPremium
effRequireOTE = isPremium or i_requireOTE
effRsiBuyMin  = isScalper ? 40 : i_rsiBuyMin
effRsiBuyMax  = isScalper ? 80 : i_rsiBuyMax
effRsiSellMin = isScalper ? 20 : i_rsiSellMin
effRsiSellMax = isScalper ? 60 : i_rsiSellMax

// Trend (uses HTF scoring — softer than hard alignment)
trendBull = emaFast > emaSlow and htfScorePassBull
trendBear = emaFast < emaSlow and htfScorePassBear

momBull = rsi[1] >= effRsiBuyMin  and rsi[1] <= effRsiBuyMax  and macdLine[1] > macdSig[1]
momBear = rsi[1] >= effRsiSellMin and rsi[1] <= effRsiSellMax and macdLine[1] < macdSig[1]

// Additive structure triggers: SMC OR Liquidity Sweep OR Hidden Divergence
structureBull = smcBullStructure or bullSweep or hiddenDivBull
structureBear = smcBearStructure or bearSweep or hiddenDivBear

smcCheckBull = not effRequireSMC or smcBullStructure
smcCheckBear = not effRequireSMC or smcBearStructure
structureOk_Bull = isPremium ? smcCheckBull : structureBull
structureOk_Bear = isPremium ? smcCheckBear : structureBear

oteFilterEff = not effRequireOTE or inOTEZone

isBuySignal  = trendBull and momBull and structureOk_Bull and activeSession and oteFilterEff and barstate.isconfirmed and inDateWindow
isSellSignal = trendBear and momBear and structureOk_Bear and activeSession and oteFilterEff and barstate.isconfirmed and inDateWindow


// ═══════════════════════════════════════════════════════════════════════════
// 6. STRATEGY ORDERS
// ═══════════════════════════════════════════════════════════════════════════

f_calcSL(isBuy, entry) =>
    atrSL   = isBuy ? entry - atr * i_atrMult : entry + atr * i_atrMult
    swingSL = isBuy ? ta.lowest(low, i_swingLookback) : ta.highest(high, i_swingLookback)
    i_useSwingSL ? (isBuy ? math.min(atrSL, swingSL) : math.max(atrSL, swingSL)) : atrSL

if isBuySignal and strategy.position_size == 0
    entry = close
    sl    = f_calcSL(true, entry)
    risk  = entry - sl
    tp1   = entry + risk * i_rrTP1
    tp2   = entry + risk * i_rrTP2
    tp3   = entry + risk * i_rrTP3
    tp4   = entry + risk * i_rrTP4
    strategy.entry("Long", strategy.long)
    strategy.exit("TP1", from_entry="Long", stop=sl, limit=tp1, qty_percent=i_tp1Pct)
    strategy.exit("TP2", from_entry="Long", stop=sl, limit=tp2, qty_percent=i_tp2Pct)
    strategy.exit("TP3", from_entry="Long", stop=sl, limit=tp3, qty_percent=i_tp3Pct)
    strategy.exit("TP4", from_entry="Long", stop=sl, limit=tp4)

if isSellSignal and strategy.position_size == 0
    entry = close
    sl    = f_calcSL(false, entry)
    risk  = sl - entry
    tp1   = entry - risk * i_rrTP1
    tp2   = entry - risk * i_rrTP2
    tp3   = entry - risk * i_rrTP3
    tp4   = entry - risk * i_rrTP4
    strategy.entry("Short", strategy.short)
    strategy.exit("TP1", from_entry="Short", stop=sl, limit=tp1, qty_percent=i_tp1Pct)
    strategy.exit("TP2", from_entry="Short", stop=sl, limit=tp2, qty_percent=i_tp2Pct)
    strategy.exit("TP3", from_entry="Short", stop=sl, limit=tp3, qty_percent=i_tp3Pct)
    strategy.exit("TP4", from_entry="Short", stop=sl, limit=tp4)


// ═══════════════════════════════════════════════════════════════════════════
// 7. VISUALS (same arrows as indicator for cross-check)
// ═══════════════════════════════════════════════════════════════════════════

plotshape(isBuySignal,  "BUY",  shape.triangleup,   location.belowbar, color.new(color.green, 0), size=size.normal)
plotshape(isSellSignal, "SELL", shape.triangledown, location.abovebar, color.new(color.red,   0), size=size.normal)
