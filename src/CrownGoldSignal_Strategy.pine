//@version=6
// ═══════════════════════════════════════════════════════════════════════════
// 👑 Crown Gold Signal V2 — Strategy (for Backtest)
// © 2026 Crown FX Automation. All rights reserved.
// ═══════════════════════════════════════════════════════════════════════════
// Mirrors indicator V2 logic (ICT Silver Bullet for Gold) with strategy orders
// Use this to validate winrate / PF / max DD before publishing.
// ═══════════════════════════════════════════════════════════════════════════

strategy(
     title                  = "Crown Gold Signal V2 — Strategy",
     shorttitle             = "👑 CGS v2 Strat",
     overlay                = true,
     initial_capital        = 100,
     default_qty_type       = strategy.percent_of_equity,
     default_qty_value      = 2,
     commission_type        = strategy.commission.percent,
     commission_value       = 0.05,
     slippage               = 3,
     pyramiding             = 0,
     calc_on_every_tick     = false,
     process_orders_on_close= true,
     max_lines_count        = 500,
     max_boxes_count        = 500,
     max_labels_count       = 500)


// ═══════════════════════════════════════════════════════════════════════════
// 1. INPUTS (mirrors indicator)
// ═══════════════════════════════════════════════════════════════════════════

G_MODE = "🎯 Signal Mode"
i_signalMode = input.string("🔥 Active Gold", "Signal Mode",
     options=["💎 Premium (Strict)", "🔥 Active Gold", "⚡ Scalper"], group=G_MODE)

G_SESS = "⏰ Sessions (Bangkok)"
i_asianSess  = input.session("0700-1400", "Asian Range", group=G_SESS)
i_londonKZ   = input.session("1400-1700", "London Killzone", group=G_SESS)
i_nyKZ       = input.session("2030-2330", "NY Killzone", group=G_SESS)
i_enableNYKZ = input.bool(true, "Also trade NY Killzone", group=G_SESS)

G_SB = "🎣 Silver Bullet"
i_sweepMaxBars = input.int(5,  "Max bars for sweep + close back", minval=1, maxval=10, group=G_SB)
i_fvgWaitBars  = input.int(10, "Max bars to wait for FVG",        minval=3, maxval=30, group=G_SB)
i_entryOnFVG   = input.string("On FVG formation", "Entry Trigger", options=["On FVG formation", "On retrace into FVG"], group=G_SB)

G_HTF = "📊 HTF Bias"
i_enableHTF = input.bool(true, "Enable HTF Bias Filter", group=G_HTF)
i_htfTF     = input.timeframe("240", "HTF Timeframe", group=G_HTF)
i_htfEmaLen = input.int(50, "HTF EMA Length", minval=10, maxval=200, group=G_HTF)

G_ATR = "🌪️ ATR Regime"
i_enableAtrRegime = input.bool(true, "Skip low-volatility days", group=G_ATR)
i_atrLen          = input.int(14, "ATR Length", group=G_ATR)
i_atrMedianDays   = input.int(30, "ATR Median Lookback (days)", group=G_ATR)
i_atrMinRatio     = input.float(0.4, "Min ATR / Median ratio", step=0.05, group=G_ATR)

G_RISK = "🛡️ Risk"
i_slBufferATR = input.float(0.5, "SL Buffer (× ATR)", step=0.1, group=G_RISK)
i_rrTP1       = input.float(1.0, "TP1 R:R", step=0.1, group=G_RISK)
i_rrTP2       = input.float(2.0, "TP2 R:R", step=0.1, group=G_RISK)
i_rrTP3       = input.float(3.0, "TP3 R:R", step=0.1, group=G_RISK)

G_POS = "📐 Position Management"
i_tp1Pct = input.float(40, "TP1 Close %", minval=0, maxval=100, group=G_POS)
i_tp2Pct = input.float(35, "TP2 Close %", minval=0, maxval=100, group=G_POS)
// Remaining (~25%) runs to TP3

G_BT = "📅 Backtest Window"
i_useDateFilter = input.bool(true, "Use Date Range Filter", group=G_BT)
i_startDate     = input.time(timestamp("2022-01-01 00:00"), "Start Date", group=G_BT)
i_endDate       = input.time(timestamp("2026-12-31 23:59"), "End Date",   group=G_BT)

inDateWindow = not i_useDateFilter or (time >= i_startDate and time <= i_endDate)


// ═══════════════════════════════════════════════════════════════════════════
// 2. SESSIONS
// ═══════════════════════════════════════════════════════════════════════════

TZ = "Asia/Bangkok"
inAsian = not na(time(timeframe.period, i_asianSess, TZ))
inLonKZ = not na(time(timeframe.period, i_londonKZ,  TZ))
inNyKZ  = i_enableNYKZ and not na(time(timeframe.period, i_nyKZ, TZ))
inKZ    = inLonKZ or inNyKZ


// ═══════════════════════════════════════════════════════════════════════════
// 3. ASIAN RANGE
// ═══════════════════════════════════════════════════════════════════════════

var float asiaHigh = na
var float asiaLow  = na
var bool  asiaSwept = false

asianSessStarted = inAsian and not inAsian[1]
if asianSessStarted
    asiaHigh  := high
    asiaLow   := low
    asiaSwept := false
else if inAsian
    asiaHigh := math.max(nz(asiaHigh, high), high)
    asiaLow  := math.min(nz(asiaLow,  low),  low)


// ═══════════════════════════════════════════════════════════════════════════
// 4. SWEEP + FVG WAIT
// ═══════════════════════════════════════════════════════════════════════════

validSetupTime = inKZ and not asiaSwept and not na(asiaHigh) and not na(asiaLow)
bullSweep = validSetupTime and low  < asiaLow  and close > asiaLow
bearSweep = validSetupTime and high > asiaHigh and close < asiaHigh

var bool  waitBullFVG  = false
var bool  waitBearFVG  = false
var int   sweepBar     = na
var float sweepExtreme = na

if bullSweep
    waitBullFVG := true
    waitBearFVG := false
    sweepBar := bar_index
    sweepExtreme := low
    asiaSwept := true
if bearSweep
    waitBearFVG := true
    waitBullFVG := false
    sweepBar := bar_index
    sweepExtreme := high
    asiaSwept := true

if not na(sweepBar) and bar_index - sweepBar > i_fvgWaitBars
    waitBullFVG := false
    waitBearFVG := false

if waitBullFVG and close < sweepExtreme
    waitBullFVG := false
if waitBearFVG and close > sweepExtreme
    waitBearFVG := false

bullFVG = low > high[2]
bearFVG = high < low[2]

var float activeBullFVGTop = na
var float activeBullFVGBot = na
var float activeBearFVGTop = na
var float activeBearFVGBot = na
var int   activeBullFVGBar = na
var int   activeBearFVGBar = na

if waitBullFVG and bullFVG
    activeBullFVGTop := low
    activeBullFVGBot := high[2]
    activeBullFVGBar := bar_index
if waitBearFVG and bearFVG
    activeBearFVGTop := low[2]
    activeBearFVGBot := high
    activeBearFVGBar := bar_index


// ═══════════════════════════════════════════════════════════════════════════
// 5. HTF + ATR FILTERS
// ═══════════════════════════════════════════════════════════════════════════

f_htfBias() =>
    ema = ta.ema(close, i_htfEmaLen)
    close > ema

htfBullBiasRaw = request.security(syminfo.tickerid, i_htfTF, f_htfBias(), lookahead=barmerge.lookahead_off)
htfBullBias = not i_enableHTF or htfBullBiasRaw
htfBearBias = not i_enableHTF or not htfBullBiasRaw

atr = ta.atr(i_atrLen)
atrMedian = request.security(syminfo.tickerid, "D", ta.median(ta.atr(i_atrLen), i_atrMedianDays), lookahead=barmerge.lookahead_off)
atrRatio = nz(atr / atrMedian, 1.0)
atrRegimeOk = not i_enableAtrRegime or atrRatio >= i_atrMinRatio


// ═══════════════════════════════════════════════════════════════════════════
// 6. SIGNAL ENGINE
// ═══════════════════════════════════════════════════════════════════════════

isPremium = i_signalMode == "💎 Premium (Strict)"
isActive  = i_signalMode == "🔥 Active Gold"
isScalper = i_signalMode == "⚡ Scalper"

effHTFBull = isPremium or isActive ? htfBullBias : true
effHTFBear = isPremium or isActive ? htfBearBias : true
effATROk   = isPremium ? atrRegimeOk : true

entryOnForm = i_entryOnFVG == "On FVG formation"

bullEntryFormation = waitBullFVG and bullFVG and barstate.isconfirmed
bullEntryRetrace   = not na(activeBullFVGTop) and bar_index - activeBullFVGBar <= 5 and low <= activeBullFVGTop and low >= activeBullFVGBot and close > activeBullFVGBot and barstate.isconfirmed
bullEntryTrigger   = entryOnForm ? bullEntryFormation : bullEntryRetrace

bearEntryFormation = waitBearFVG and bearFVG and barstate.isconfirmed
bearEntryRetrace   = not na(activeBearFVGTop) and bar_index - activeBearFVGBar <= 5 and high >= activeBearFVGBot and high <= activeBearFVGTop and close < activeBearFVGTop and barstate.isconfirmed
bearEntryTrigger   = entryOnForm ? bearEntryFormation : bearEntryRetrace

pivotHi20 = ta.highest(high, 20)[1]
pivotLo20 = ta.lowest(low,   20)[1]
scalperBullSweep = isScalper and inKZ and low < pivotLo20 and close > pivotLo20
scalperBearSweep = isScalper and inKZ and high > pivotHi20 and close < pivotHi20

isBuySignal  = (bullEntryTrigger or scalperBullSweep) and effHTFBull and effATROk and inDateWindow
isSellSignal = (bearEntryTrigger or scalperBearSweep) and effHTFBear and effATROk and inDateWindow

if isBuySignal
    waitBullFVG := false
if isSellSignal
    waitBearFVG := false


// ═══════════════════════════════════════════════════════════════════════════
// 7. STRATEGY ORDERS
// ═══════════════════════════════════════════════════════════════════════════

f_calcSL(isBuy, sweepExt) =>
    buf = atr * i_slBufferATR
    isBuy ? sweepExt - buf : sweepExt + buf

if isBuySignal and strategy.position_size == 0
    entry = close
    sl    = f_calcSL(true, sweepExtreme)
    risk  = entry - sl
    tp1   = entry + risk * i_rrTP1
    tp2   = entry + risk * i_rrTP2
    tp3   = entry + risk * i_rrTP3
    strategy.entry("Long", strategy.long)
    strategy.exit("TP1", from_entry="Long", stop=sl, limit=tp1, qty_percent=i_tp1Pct)
    strategy.exit("TP2", from_entry="Long", stop=sl, limit=tp2, qty_percent=i_tp2Pct)
    strategy.exit("TP3", from_entry="Long", stop=sl, limit=tp3)

if isSellSignal and strategy.position_size == 0
    entry = close
    sl    = f_calcSL(false, sweepExtreme)
    risk  = sl - entry
    tp1   = entry - risk * i_rrTP1
    tp2   = entry - risk * i_rrTP2
    tp3   = entry - risk * i_rrTP3
    strategy.entry("Short", strategy.short)
    strategy.exit("TP1", from_entry="Short", stop=sl, limit=tp1, qty_percent=i_tp1Pct)
    strategy.exit("TP2", from_entry="Short", stop=sl, limit=tp2, qty_percent=i_tp2Pct)
    strategy.exit("TP3", from_entry="Short", stop=sl, limit=tp3)


// ═══════════════════════════════════════════════════════════════════════════
// 8. VISUALS
// ═══════════════════════════════════════════════════════════════════════════

plotshape(isBuySignal,  "BUY",  shape.triangleup,   location.belowbar, color.new(color.green, 0), size=size.normal)
plotshape(isSellSignal, "SELL", shape.triangledown, location.abovebar, color.new(color.red,   0), size=size.normal)
